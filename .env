# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./db/github_clone.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
